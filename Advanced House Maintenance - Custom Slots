def appendTaskSection(StringBuilder html, String title, List taskList, String colorClass, Boolean openByDefault) {
    if (!taskList) return
    html.append("<details ${openByDefault ? 'open' : ''}><summary>${htmlEncode(title)} <span style='float:right;font-size:12px;color:#888;'>${taskList.size()} Tasks</span></summary><div class='folder-content'>")
    taskList.sort { it.days }.each { t ->
        html.append(buildTaskCard(t, colorClass))
    }
    html.append("</div></details>")
}

def appendCategorySections(StringBuilder html, List taskList) {
    if (!taskList) return

    def grouped = taskList.groupBy { it.category ?: "General" }
    grouped.keySet().sort().each { catName ->
        def catTasks = grouped[catName]
        html.append("<details class='category-folder'><summary style='border-left-color:#3498db;'>📁 ${htmlEncode(catName)} <span style='float:right;font-size:12px;color:#888;'>${catTasks.size()} Tasks</span></summary><div class='folder-content'>")
        catTasks.sort { it.days }.each { t ->
            html.append(buildTaskCard(t, "green"))
        }
        html.append("</div></details>")
    }
}

def buildTaskCard(Map t, String colorClass) {
    def desc = t.description ? htmlEncode(t.description) : "No description"
    def sub = "${htmlEncode(t.scheduleLabel)} • Last: ${formatDateMs(t.lastCompleted)} • Next: ${formatDateMs(t.dueDateMs)}"
    def controls = "<div class='controls'>"
    if (t.muted) {
        controls += "<span style='color:#9b59b6;font-size:12px;'>Muted until ${formatDateMs(t.muteUntil)}</span>"
        controls += "<a href='unmute?taskId=${t.id}&access_token=${state.accessToken}' class='btn' style='background:#8e44ad;border-color:#8e44ad;'>Unmute</a>"
    } else {
        controls += "<button class='btn' onclick=\"markComplete('${t.id}', this)\">Complete</button>"
        controls += "<form action='mute' method='GET' class='mute-form'><input type='hidden' name='taskId' value='${t.id}'><input type='hidden' name='access_token' value='${state.accessToken}'><input type='number' name='days' class='mute-input' placeholder='days' required min='1'><button type='submit' class='mute-btn'>Mute</button></form>"
    }
    controls += "</div>"

    return "<div class='task-card ${colorClass}' id='card-${t.id}'><div class='task-info'><div class='task-name'>${htmlEncode(t.name)}</div><div class='task-details'>${desc}</div><div class='task-sub'>${htmlEncode(dueLabel(t.days))} • ${sub}</div></div>${controls}</div>"
}

def webCompleteTask() {
    def taskId = params.id
    if (taskId) {
        completeTask(taskId)
        render contentType: "application/json", data: '{"status":"success"}', status: 200
    } else {
        render contentType: "application/json", data: '{"status":"error", "message":"No ID provided"}', status: 400
    }
}

def webMuteTask() {
    try {
        def tId = params.taskId
        def days = params.days
        if (tId && days && days.toString().isInteger()) {
            long muteUntil = now() + ((long)days.toInteger() * dayMs())
            if (state.muteExpirations == null) state.muteExpirations = [:]
            state.muteExpirations[tId] = muteUntil
            def task = getConfiguredTasks().find { it.id == tId }
            logAction("Task '${task?.name ?: tId}' muted for ${days} days via portal.")
            updateChildDevice()
        }
        return render(contentType: "text/html", data: getRedirectHtml("Muting task..."), status: 200)
    } catch (e) {
        log.error "Mute error: ${e}"
        return render(contentType: "text/html", data: "Error executing mute: ${e.message}", status: 500)
    }
}

def webUnmuteTask() {
    try {
        def tId = params.taskId
        if (tId && state.muteExpirations) {
            state.muteExpirations.remove(tId)
            def task = getConfiguredTasks().find { it.id == tId }
            logAction("Task '${task?.name ?: tId}' unmuted via portal.")
            updateChildDevice()
        }
        return render(contentType: "text/html", data: getRedirectHtml("Unmuting task..."), status: 200)
    } catch (e) {
        log.error "Unmute error: ${e}"
        return render(contentType: "text/html", data: "Error executing unmute: ${e.message}", status: 500)
    }
}

def getRedirectHtml(String msgText) {
    return "<!DOCTYPE html><html><head><meta name='viewport' content='width=device-width, initial-scale=1'><script>setTimeout(function(){window.location.href='dashboard?access_token=${state.accessToken}';}, 0);</script></head><body style='background:#0d0d0d;color:#fff;text-align:center;padding-top:100px;font-family:sans-serif;'><h3>Syncing Portal...</h3><p style='color:#666;'>${htmlEncode(msgText)}</p></body></html>"
}

