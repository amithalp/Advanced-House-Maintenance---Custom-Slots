/**
 * Advanced House Maintenance - Custom Slots
 *
 * Modified concept/version for amitHalp
 * - No predefined task database
 * - 20 reserved configurable task slots
 * - User-defined task names, categories, descriptions, intervals and costs
 * - Supported scheduling modes:
 *   1. After Completion
 *   2. Fixed Interval From First Due Date
 *   3. Annual Fixed Date
 *   4. Monthly Fixed Day
 * - Centralized due-date calculation
 *
 * Notes:
 * - This is an app-only version.
 * - If you use the optional child tile, keep the original child driver installed:
 *   "Maintenance Dashboard Tile" by namespace "ShaneAllen".
 */

Integer getTaskSlotCount() { return 20 }

String scheduleAfterCompletion() { return "after_completion" }
String scheduleFixedInterval() { return "fixed_interval_from_first_due" }
String scheduleAnnualFixedDate() { return "annual_fixed_date" }
String scheduleMonthlyFixedDay() { return "monthly_fixed_day" }

Long dayMs() { return 86400000L }

definition(
    name: "Advanced House Maintenance - Custom Slots",
    namespace: "ShaneAllen",
    author: "ShaneAllen",
    description: "User-configurable household maintenance tracker with 20 custom task slots and multiple scheduling modes.",
    category: "Convenience",
    iconUrl: "",
    iconX2Url: "",
    iconX3Url: "",
    oauth: true
)

preferences {
    page(name: "mainPage")
}

mappings {
    path("/dashboard") { action: [GET: "serveDashboard"] }
    path("/dashboard/complete/:id") { action: [GET: "webCompleteTask"] }
    path("/mute") { action: [GET: "webMuteTask"] }
    path("/unmute") { action: [GET: "webUnmuteTask"] }
}

