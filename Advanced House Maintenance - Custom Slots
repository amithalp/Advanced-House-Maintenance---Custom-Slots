// =============================================================================
// Lifecycle
// =============================================================================

def installed() {
    logInfo("Installed")
    initialize()
}

def updated() {
    logInfo("Updated")
    unsubscribe()
    unschedule()
    initialize()
}

def initialize() {
    ensureStateMaps()
    initializeActiveTaskData()

    if (appEnableSwitch) subscribe(appEnableSwitch, "switch", enableSwitchHandler)
    subscribe(location, "systemStart", hubRestartHandler)

    scheduleDailyCheck()
    updateChildDevice()
    logAction("App initialized.")
}

def ensureStateMaps() {
    if (state.actionHistory == null) state.actionHistory = []
    if (state.taskData == null) state.taskData = [:]
    if (state.muteExpirations == null) state.muteExpirations = [:]
}

def initializeActiveTaskData() {
    def tempData = state.taskData ?: [:]
    boolean changed = false

    getConfiguredTasks().each { task ->
        if (!tempData[task.id]) {
            tempData[task.id] = [lastCompleted: 0L, snoozedUntil: 0L, completedOccurrences: []]
            changed = true
            logAction("Tracking started for: ${task.name}")
        } else {
            if (tempData[task.id].snoozedUntil == null) tempData[task.id].snoozedUntil = 0L
            if (tempData[task.id].completedOccurrences == null) tempData[task.id].completedOccurrences = []
        }
    }

    if (changed) state.taskData = tempData
}

def scheduleDailyCheck() {
    unschedule(dailyMaintenanceCheck)
    if (checkTime) schedule(checkTime, dailyMaintenanceCheck)
    else schedule("0 0 9 * * ?", dailyMaintenanceCheck)
}

def hubRestartHandler(evt) {
    scheduleDailyCheck()
}

def enableSwitchHandler(evt) {
    if (evt.value == "off") logAction("App disabled via master switch.")
    else logAction("App enabled via master switch.")
}

// =============================================================================
// Task Configuration
// =============================================================================

def getConfiguredTasks() {
    def tasks = []

    (1..getTaskSlotCount()).each { n ->
        def id = taskIdForSlot(n)
        def enabled = settings["${id}_enabled"] == true
        def name = settings["${id}_name"]?.toString()?.trim()

        if (enabled && name) {
            tasks << [
                id: id,
                slot: n,
                name: name,
                category: resolveCategoryName(settings["${id}_category"]),
                description: settings["${id}_description"]?.toString()?.trim() ?: "",
                scheduleType: settings["${id}_scheduleType"] ?: scheduleAfterCompletion(),
                intervalDays: safeInteger(settings["${id}_intervalDays"], 30),
                firstDueDate: settings["${id}_firstDueDate"],
                month: safeInteger(settings["${id}_month"], 1),
                dayOfMonth: safeInteger(settings["${id}_dayOfMonth"], 1),
                consumable: settings["${id}_consumable"] == true,
                estCost: safeDecimal(settings["${id}_estCost"], 0.0)
            ]
        }
    }

    return tasks
}

def taskIdForSlot(Integer n) {
    return String.format("task_%02d", n)
}

def scheduleTypeOptions() {
    return [
        (scheduleAfterCompletion()): "After completion - interval starts when task is completed",
        (scheduleFixedInterval()): "Fixed interval from first due date",
        (scheduleAnnualFixedDate()): "Annual fixed date - every year on selected month/day",
        (scheduleMonthlyFixedDay()): "Monthly fixed day - every month on selected day"
    ]
}

def monthOptions() {
    return [
        "1": "January",
        "2": "February",
        "3": "March",
        "4": "April",
        "5": "May",
        "6": "June",
        "7": "July",
        "8": "August",
        "9": "September",
        "10": "October",
        "11": "November",
        "12": "December"
    ]
}

def getCategoryOptions() {
    def opts = [:]
    (1..10).each { n ->
        def name = settings["category_${n}"]?.toString()?.trim()
        if (!name) name = defaultCategoryName(n)
        opts[n.toString()] = name
    }
    return opts
}

def resolveCategoryName(def categoryValue) {
    if (!categoryValue) return defaultCategoryName(1)
    def key = categoryValue.toString()
    def opts = getCategoryOptions()
    return opts[key] ?: key
}

def defaultCategoryName(Integer n) {
    def defaults = [
        1: "General",
        2: "Pool & Spa",
        3: "Smart Home",
        4: "Safety & Security",
        5: "Garden & Outdoors",
        6: "Power & Electrical",
        7: "Water Systems",
        8: "Vehicle Maintenance",
        9: "Financial & Admin",
        10: "Other"
    ]
    return defaults[n] ?: "Category ${n}"
}

// =============================================================================
// Due-Date Logic
// =============================================================================

def getActiveTasksForDisplay() {
    ensureStateMaps()
    def nowMs = now()
    def results = []

    clearExpiredMutes(nowMs)

    getConfiguredTasks().each { task ->
        def taskData = state.taskData[task.id]
        if (!taskData) {
            taskData = [lastCompleted: 0L, snoozedUntil: 0L, completedOccurrences: []]
            state.taskData[task.id] = taskData
        }

        def dueDateMs = calculateNextDueDateMs(task, taskData, nowMs)
        def days = daysUntil(dueDateMs, nowMs)
        def muted = isTaskMuted(task.id, nowMs)
        def snoozed = taskData.snoozedUntil != null && taskData.snoozedUntil > nowMs

        results << task + [
            dueDateMs: dueDateMs,
            days: days,
            lastCompleted: taskData.lastCompleted ?: 0L,
            muted: muted,
            snoozed: snoozed,
            muteUntil: muted ? state.muteExpirations[task.id] : null,
            scheduleLabel: getScheduleLabel(task)
        ]
    }

    return results
}

def calculateNextDueDateMs(Map task, Map taskData, Long nowMs) {
    def scheduleType = task.scheduleType ?: scheduleAfterCompletion()

    if (scheduleType == scheduleAfterCompletion()) {
        def lastCompleted = taskData.lastCompleted ?: 0L
        if (lastCompleted <= 0L) return startOfTodayMs(nowMs)
        return startOfDayMs(lastCompleted + ((long)task.intervalDays * dayMs()))
    }

    if (scheduleType == scheduleFixedInterval()) {
        def firstDueMs = parseDateSettingToStartOfDayMs(task.firstDueDate)
        if (!firstDueMs) return startOfTodayMs(nowMs)
        def intervalMs = Math.max(1, task.intervalDays as Integer) * dayMs()
        def candidate = firstDueMs

        if (candidate < startOfTodayMs(nowMs)) {
            long periods = Math.floor((startOfTodayMs(nowMs) - candidate) / intervalMs).toLong()
            candidate = candidate + (periods * intervalMs)
            while (candidate < startOfTodayMs(nowMs) && isOccurrenceCompleted(taskData, candidate)) {
                candidate += intervalMs
            }
            if (candidate < startOfTodayMs(nowMs)) candidate += intervalMs
        }

        while (isOccurrenceCompleted(taskData, candidate)) {
            candidate += intervalMs
        }
        return startOfDayMs(candidate)
    }

    if (scheduleType == scheduleAnnualFixedDate()) {
        Calendar cal = Calendar.getInstance(location.timeZone)
        cal.setTimeInMillis(nowMs)
        int year = cal.get(Calendar.YEAR)
        int month = clamp(task.month as Integer, 1, 12)
        int day = clamp(task.dayOfMonth as Integer, 1, 31)

        long candidate = dateToMs(year, month, day)
        if (candidate < startOfTodayMs(nowMs) || isOccurrenceCompleted(taskData, candidate)) {
            candidate = dateToMs(year + 1, month, day)
        }
        while (isOccurrenceCompleted(taskData, candidate)) {
            year++
            candidate = dateToMs(year + 1, month, day)
        }
        return candidate
    }

    if (scheduleType == scheduleMonthlyFixedDay()) {
        Calendar cal = Calendar.getInstance(location.timeZone)
        cal.setTimeInMillis(nowMs)
        int year = cal.get(Calendar.YEAR)
        int month = cal.get(Calendar.MONTH) + 1
        int day = clamp(task.dayOfMonth as Integer, 1, 31)

        long candidate = dateToMs(year, month, day)
        if (candidate < startOfTodayMs(nowMs) || isOccurrenceCompleted(taskData, candidate)) {
            cal.set(Calendar.DAY_OF_MONTH, 1)
            cal.add(Calendar.MONTH, 1)
            year = cal.get(Calendar.YEAR)
            month = cal.get(Calendar.MONTH) + 1
            candidate = dateToMs(year, month, day)
        }
        while (isOccurrenceCompleted(taskData, candidate)) {
            cal.setTimeInMillis(candidate)
            cal.set(Calendar.DAY_OF_MONTH, 1)
            cal.add(Calendar.MONTH, 1)
            year = cal.get(Calendar.YEAR)
            month = cal.get(Calendar.MONTH) + 1
            candidate = dateToMs(year, month, day)
        }
        return candidate
    }

    return startOfTodayMs(nowMs)
}

def isOccurrenceCompleted(Map taskData, Long dueDateMs) {
    def completed = taskData.completedOccurrences ?: []
    return completed.contains(startOfDayMs(dueDateMs).toString())
}

def markOccurrenceCompleted(Map taskData, Long dueDateMs) {
    def completed = taskData.completedOccurrences ?: []
    def key = startOfDayMs(dueDateMs).toString()
    if (!completed.contains(key)) completed << key
    if (completed.size() > 50) completed = completed[-50..-1]
    taskData.completedOccurrences = completed
}

def getScheduleLabel(Map task) {
    def scheduleType = task.scheduleType ?: scheduleAfterCompletion()
    if (scheduleType == scheduleAfterCompletion()) return "Every ${task.intervalDays} days after completion"
    if (scheduleType == scheduleFixedInterval()) return "Every ${task.intervalDays} days from ${task.firstDueDate ?: 'first due date'}"
    if (scheduleType == scheduleAnnualFixedDate()) return "Every year on ${monthName(task.month)} ${task.dayOfMonth}"
    if (scheduleType == scheduleMonthlyFixedDay()) return "Every month on day ${task.dayOfMonth}"
    return "Unknown"
}

// =============================================================================
// Actions
// =============================================================================

def appButtonHandler(btn) {
    ensureStateMaps()

    if (btn == "btnRefresh") {
        updateChildDevice()
    }
    else if (btn == "btnCreateDevice") {
        createIntegrationDevice()
    }
    else if (btn == "resetHistory") {
        state.actionHistory = []
    }
    else if (btn.startsWith("btnDashComplete_")) {
        completeTask(btn.replace("btnDashComplete_", ""))
    }
    else if (btn.startsWith("btnSnooze_")) {
        snoozeTask(btn.replace("btnSnooze_", ""))
    }
}

def completeTask(String taskId) {
    ensureStateMaps()
    def task = getConfiguredTasks().find { it.id == taskId }
    if (!task) return

    def tempData = state.taskData ?: [:]
    def taskData = tempData[taskId] ?: [lastCompleted: 0L, snoozedUntil: 0L, completedOccurrences: []]
    def nowMs = now()
    def dueDateMs = calculateNextDueDateMs(task, taskData, nowMs)

    taskData.lastCompleted = nowMs
    taskData.snoozedUntil = 0L

    if ((task.scheduleType ?: scheduleAfterCompletion()) != scheduleAfterCompletion()) {
        markOccurrenceCompleted(taskData, dueDateMs)
    }

    tempData[taskId] = taskData
    state.taskData = tempData

    def nextDue = calculateNextDueDateMs(task, taskData, nowMs)
    logAction("Completed: '${task.name}'. Next due: ${formatDateMs(nextDue)}.")
    updateChildDevice()
}

def snoozeTask(String taskId) {
    ensureStateMaps()
    def task = getConfiguredTasks().find { it.id == taskId }
    if (!task) return

    Calendar cal = Calendar.getInstance(location.timeZone)
    int today = cal.get(Calendar.DAY_OF_WEEK)
    int addDays = Calendar.SATURDAY - today
    if (addDays <= 0) addDays += 7

    def tempData = state.taskData ?: [:]
    def taskData = tempData[taskId] ?: [lastCompleted: 0L, snoozedUntil: 0L, completedOccurrences: []]
    taskData.snoozedUntil = now() + ((long)addDays * dayMs())
    tempData[taskId] = taskData
    state.taskData = tempData

    logAction("Task '${task.name}' snoozed until Saturday.")
    updateChildDevice()
}

def createIntegrationDevice() {
    def childId = "AHM_${app.id}"
    if (!getChildDevice(childId)) {
        try {
            addChildDevice("ShaneAllen", "Maintenance Dashboard Tile", childId, null, [name: "Advanced House Maintenance Device"])
            logAction("Created dashboard tile child device.")
            runIn(2, "updateChildDevice")
        } catch (e) {
            log.error "Failed to create child device. Ensure 'Maintenance Dashboard Tile' driver is installed. Error: ${e}"
        }
    } else {
        logInfo("Dashboard tile child device already exists.")
    }
}

