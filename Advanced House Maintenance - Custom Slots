def getStatusHtml() {
    def tasks = getActiveTasksForDisplay()
    def overdue = tasks.count { !it.muted && !it.snoozed && it.days < 0 }
    def dueToday = tasks.count { !it.muted && !it.snoozed && it.days == 0 }
    def upcoming = tasks.count { !it.muted && !it.snoozed && it.days > 0 && it.days <= safeInteger(upcomingDays, 7) }
    def muted = tasks.count { it.muted }
    def snoozed = tasks.count { it.snoozed }

    def msg
    if (appEnableSwitch && appEnableSwitch.currentValue("switch") == "off") msg = "<span style='color:red;'>Disabled via master switch. Notifications paused.</span>"
    else if (overdue > 0) msg = "<span style='color:red;'><b>Requires attention:</b></span> ${overdue} task(s) overdue."
    else if (dueToday > 0) msg = "<span style='color:darkorange;'><b>Due today:</b></span> ${dueToday} task(s) due today."
    else if (upcoming > 0) msg = "<span style='color:orange;'><b>Upcoming:</b></span> ${upcoming} task(s) approaching due date."
    else if (snoozed > 0 || muted > 0) msg = "<span style='color:purple;'><b>Deferred:</b></span> ${snoozed} snoozed / ${muted} muted task(s)."
    else msg = "<span style='color:green;'><b>All good:</b></span> All active tasks are up to date."

    return "<div style='background-color:#e9ecef;padding:10px;border-radius:5px;border-left:5px solid #007bff;margin-bottom:20px;'><b>System Status:</b> ${msg}</div>"
}

def getTaskPreviewHtml(String id) {
    def task = getConfiguredTasks().find { it.id == id }
    if (!task) return ""

    def data = state.taskData ? state.taskData[id] : null
    if (!data) data = [lastCompleted: 0L, snoozedUntil: 0L, completedOccurrences: []]
    def due = calculateNextDueDateMs(task, data, now())
    def days = daysUntil(due, now())

    return "<div style='font-size:12px;color:#444;background-color:#f8f9fa;padding:8px;border-radius:4px;border-left:4px solid #17a2b8;margin-top:8px;'>" +
        "<b>Preview:</b> ${htmlEncode(getScheduleLabel(task))}<br>" +
        "<b>Next Due:</b> ${formatDateMs(due)} — ${htmlEncode(dueLabel(days))}" +
        "</div>"
}

def statusTextHtml(Map t) {
    if (t.muted) return "<span style='color:#8e44ad;font-weight:bold;'>MUTED</span>"
    if (t.snoozed) return "<span style='color:purple;font-weight:bold;'>SNOOZED</span>"
    if (t.days < 0) return "<span style='color:red;font-weight:bold;'>OVERDUE (${Math.abs(t.days)} days)</span>"
    if (t.days == 0) return "<span style='color:darkorange;font-weight:bold;'>DUE TODAY</span>"
    if (t.days <= safeInteger(upcomingDays, 7)) return "<span style='color:orange;font-weight:bold;'>Due soon (${t.days} days)</span>"
    return "<span style='color:green;'>Good (${t.days} days left)</span>"
}

def dueLabel(Integer days) {
    if (days < 0) return "Overdue by ${Math.abs(days)} days"
    if (days == 0) return "Due today"
    if (days == 1) return "Due tomorrow"
    return "Due in ${days} days"
}

// =============================================================================
// Date / Utility Helpers
// =============================================================================

def parseDateSettingToStartOfDayMs(def dateValue) {
    if (!dateValue) return null
    try {
        if (dateValue instanceof Date) return startOfDayMs(dateValue.time)
        String s = dateValue.toString()
        return startOfDayMs(Date.parse("yyyy-MM-dd", s).time)
    } catch (e) {
        try {
            return startOfDayMs(new Date(dateValue.toString()).time)
        } catch (ignored) {
            return null
        }
    }
}

def dateToMs(Integer year, Integer month, Integer day) {
    Calendar cal = Calendar.getInstance(location.timeZone)
    cal.clear()
    cal.set(Calendar.YEAR, year)
    cal.set(Calendar.MONTH, clamp(month, 1, 12) - 1)
    cal.set(Calendar.DAY_OF_MONTH, 1)
    int maxDay = cal.getActualMaximum(Calendar.DAY_OF_MONTH)
    cal.set(Calendar.DAY_OF_MONTH, clamp(day, 1, maxDay))
    cal.set(Calendar.HOUR_OF_DAY, 0)
    cal.set(Calendar.MINUTE, 0)
    cal.set(Calendar.SECOND, 0)
    cal.set(Calendar.MILLISECOND, 0)
    return cal.getTimeInMillis()
}

def startOfTodayMs(Long nowMs) {
    return startOfDayMs(nowMs)
}

def startOfDayMs(Long ms) {
    Calendar cal = Calendar.getInstance(location.timeZone)
    cal.setTimeInMillis(ms)
    cal.set(Calendar.HOUR_OF_DAY, 0)
    cal.set(Calendar.MINUTE, 0)
    cal.set(Calendar.SECOND, 0)
    cal.set(Calendar.MILLISECOND, 0)
    return cal.getTimeInMillis()
}

def daysUntil(Long dueDateMs, Long nowMs) {
    return Math.ceil((dueDateMs - nowMs) / 86400000.0).toInteger()
}

def formatDateMs(def ms) {
    if (!ms || ms <= 0L) return "Never"
    try {
        return new Date(ms as Long).format("MM/dd/yyyy", location.timeZone)
    } catch (e) {
        return "Invalid date"
    }
}

def monthName(def m) {
    def idx = safeInteger(m, 1)
    return monthOptions()[idx.toString()] ?: "Month ${idx}"
}

def clearExpiredMutes(Long nowMs) {
    if (!state.muteExpirations) return
    def removeKeys = []
    state.muteExpirations.each { k, v -> if ((v as Long) < nowMs) removeKeys << k }
    removeKeys.each { state.muteExpirations.remove(it) }
}

def isTaskMuted(String taskId, Long nowMs) {
    return state.muteExpirations && state.muteExpirations[taskId] != null && (state.muteExpirations[taskId] as Long) > nowMs
}

def safeInteger(def value, Integer fallback) {
    try {
        if (value == null || value == "") return fallback
        return value.toString().toInteger()
    } catch (e) {
        return fallback
    }
}

def safeDecimal(def value, BigDecimal fallback) {
    try {
        if (value == null || value == "") return fallback
        return new BigDecimal(value.toString())
    } catch (e) {
        return fallback
    }
}

def clamp(Integer value, Integer min, Integer max) {
    if (value < min) return min
    if (value > max) return max
    return value
}

def htmlEncode(def value) {
    if (value == null) return ""
    return value.toString()
        .replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace('"', "&quot;")
        .replace("'", "&#39;")
}

def logAction(String msg) {
    if (txtEnable != false) log.info "${app.label}: ${msg}"
    def h = state.actionHistory ?: []
    h.add(0, "[${new Date().format('MM/dd HH:mm', location.timeZone)}] ${htmlEncode(msg)}")
    if (h.size() > 30) h = h[0..29]
    state.actionHistory = h
}

def logAction(Object msg) {
    logAction(msg.toString())
}

def logInfo(def msg) {
    if (txtEnable != false) log.info "${app.label}: ${msg}"
}
