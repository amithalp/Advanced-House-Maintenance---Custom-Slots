// Daily Checks and Child Device
// =============================================================================

def dailyMaintenanceCheck() {
    def nowMs = now()
    updateChildDevice()

    if (appEnableSwitch && appEnableSwitch.currentValue("switch") == "off") return
    if (notifyModes && !(notifyModes as List).contains(location.mode)) return

    def threshold = safeInteger(upcomingDays, 7)
    def allowOverdueReminders = remindOverdue != null ? remindOverdue : true
    def alerts = []

    getActiveTasksForDisplay().each { t ->
        if (t.snoozed || t.muted) return
        if (t.days == threshold) alerts << "UPCOMING: '${t.name}' is due in ${t.days} days."
        else if (t.days == 0) alerts << "DUE TODAY: Time to complete '${t.name}'."
        else if (t.days < 0 && allowOverdueReminders) alerts << "OVERDUE: '${t.name}' is overdue by ${Math.abs(t.days)} days."
    }

    if (alerts) {
        def msg = "House Maintenance Alerts:\n" + alerts.join("\n")
        logAction("Notifications fired: " + alerts.join(" | "))
        if (notifyDevices) notifyDevices.deviceNotification(msg)
    }
}

def updateChildDevice() {
    def child = getChildDevice("AHM_${app.id}")
    if (!child) return

    def tasks = getActiveTasksForDisplay().sort { it.days }
    def overdueTasks = tasks.findAll { it.days < 0 && !it.snoozed && !it.muted }
    def maxOverdueDays = overdueTasks ? overdueTasks.collect { Math.abs(it.days) }.max() : 0

    child.sendEvent(name: "overdueTasks", value: overdueTasks ? overdueTasks.collect { it.name }.join(", ") : "None", isStateChange: true)
    child.sendEvent(name: "maxOverdueDays", value: maxOverdueDays, isStateChange: true)

    def html = ""
    if (tasks) {
        html += "<table style='width:100%;border-collapse:collapse;font-size:14px;font-family:sans-serif;'>"
        html += "<tr style='background-color:#343a40;color:white;'><th style='padding:6px;text-align:left;'>Top Tasks</th><th style='padding:6px;text-align:center;'>Due</th></tr>"
        tasks.take(5).each { t ->
            def color = "green"
            if (t.muted) color = "#8e44ad"
            else if (t.snoozed) color = "purple"
            else if (t.days < 0) color = "red"
            else if (t.days == 0) color = "darkorange"
            else if (t.days <= safeInteger(upcomingDays, 7)) color = "orange"
            html += "<tr><td style='padding:6px;border-bottom:1px solid #ccc;'>${htmlEncode(t.name)}</td><td style='padding:6px;border-bottom:1px solid #ccc;text-align:center;color:${color};font-weight:bold;'>${htmlEncode(dueLabel(t.days))}</td></tr>"
        }
        html += "</table>"
    } else {
        html = "<div style='padding:15px;text-align:center;font-family:sans-serif;font-size:16px;color:green;font-weight:bold;'>No active tasks</div>"
    }

    child.sendEvent(name: "htmlTile", value: html, isStateChange: true)
}

